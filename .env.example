# Server-only — never prefix with VITE_ (keys must stay off the browser bundle)
GEMINI_API_KEY=

# Optional: comma-separated extra origins (Vercel preview URLs, staging, etc.)
# ALLOWED_ORIGINS=https://william-site-git-feature-xxx.vercel.app

# Optional: allow any https://*.vercel.app origin (preview deployments)
# ALLOW_VERCEL_PREVIEWS=1
